# --- Required ---
# Bot token from https://discord.com/developers/applications  (Bot -> Reset Token)
DISCORD_TOKEN=

# --- Detection tuning ---
# Number of DISTINCT channels the same message must appear in to trip enforcement.
DUP_CHANNEL_THRESHOLD=2
# Time window in milliseconds within which those duplicates must occur (30000 = 30s).
WINDOW_MS=30000
# Messages shorter than this (after normalising) are ignored, to avoid false positives
# on normal short chatter like "gg" posted in two channels.
MIN_MESSAGE_LENGTH=8

# --- Enforcement ---
# What to do on detection:
#   ban     = ban + purge recent messages (permanent)
#   softban = ban then immediately unban = kick + purge recent messages (user can rejoin)
#   kick    = kick only, messages left in place (does NOT delete; needs Kick Members permission)
ACTION=ban
# How far back (in seconds) to purge messages (applies to ban/softban). 3600 = last hour. Max 604800 (7 days).
DELETE_SECONDS=3600
# If true, the bot logs what it WOULD do but takes no action. Use for the first live test, then set to false.
DRY_RUN=false

# --- Scope (all optional; comma-separated channel IDs) ---
# If set, ONLY these channels are watched. Empty = watch all channels.
MONITORED_CHANNEL_IDS=
# Channels to never watch (takes precedence over the monitored list).
IGNORED_CHANNEL_IDS=

# --- Safety / logging (all optional) ---
# A role whose members are never actioned (e.g. your mods). Single role ID.
IMMUNE_ROLE_ID=
# Channel to post action reports to. Empty = console logging only.
MOD_LOG_CHANNEL_ID=

# --- Storage ---
# Directory for the persistent ban log (bans.json). In Docker this maps to the rembot-data volume.
DATA_DIR=./data
